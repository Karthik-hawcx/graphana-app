{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.98 }] },
          "noValue": "N/A"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{code=~\"2..\"}[5m])) / sum(rate(kong_http_requests_total[5m]))",
          "legendFormat": ""
        }
      ],
      "title": "Auth Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total[5m]))",
          "legendFormat": ""
        }
      ],
      "title": "Total Requests/sec",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{code=\"401\"}[1m])) * 60",
          "legendFormat": ""
        }
      ],
      "title": "401s/min",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{code=\"403\"}[1m])) * 60",
          "legendFormat": ""
        }
      ],
      "title": "403s/min",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Auth Type Distribution (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "percent"] } },
      "targets": [
        {
          "expr": "sum by (auth_type) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | auth_type != \"\" [$__range]))",
          "legendFormat": "{{auth_type}}",
          "refId": "A"
        }
      ],
      "title": "DPoP vs Bearer vs Missing",
      "type": "piechart"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (auth_type) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | auth_type != \"\" [$__interval]))",
          "legendFormat": "{{auth_type}}",
          "refId": "A"
        }
      ],
      "title": "Auth Type Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Route Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 1, "spanNulls": true },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{route=~\"$route\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "title": "Requests by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 1, "spanNulls": true },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] }
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{code=~\"4..|5..\", route=~\"$route\"}[5m])) by (route) / sum(rate(kong_http_requests_total{route=~\"$route\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "title": "Error Rate by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 1, "spanNulls": true },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 19 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kong_request_latency_ms_bucket{route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "p50 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket{route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_request_latency_ms_bucket{route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "p99 {{route}}"
        }
      ],
      "title": "Latency by Route (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 103,
      "title": "DPoP Monitoring (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 30 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (route_name, dpop_present) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | route_name != \"\" [$__interval]))",
          "legendFormat": "{{route_name}} dpop={{dpop_present}}",
          "refId": "A"
        }
      ],
      "title": "DPoP Proof Present/Absent by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (auth_type) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | response_status >= 400 [$__interval]))",
          "legendFormat": "{{auth_type}} (4xx/5xx)",
          "refId": "A"
        }
      ],
      "title": "Auth Failures by Type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Tenant Activity (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 41 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (tenant_id) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | tenant_id != \"\" | tenant_id != \"unknown\" [$__interval]))",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Tenant",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 41 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (tenant_id) (count_over_time({namespace=\"kong\", app=\"kong-dataplane\"} | json | tenant_id != \"\" | tenant_id != \"unknown\" | response_status >= 400 [$__interval]))",
          "legendFormat": "{{tenant_id}} (errors)",
          "refId": "A"
        }
      ],
      "title": "Errors by Tenant",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["kong", "auth", "security", "dpop"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(kong_http_requests_total, route)",
        "includeAll": true,
        "multi": true,
        "name": "route",
        "query": "label_values(kong_http_requests_total, route)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kong Auth Security",
  "uid": "kong-auth-security",
  "version": 1
}
